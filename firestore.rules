// SafeSpend — Firestore Security Rules
//
// Paste this ENTIRE file into Firebase Console → Firestore Database → Rules → Publish.
//
// Design notes:
//   • Earnings are NEVER written directly. They are computed from `referrals` docs
//     (sum of rewardAmount where status == 'active'). This removes any cross-user
//     write path and prevents commission fraud.
//   • A referee creates their own pending referral doc at signup, and can only
//     flip their own referral to 'active' (immutable referrer/reward).
//   • Withdrawals can be created by the user but never modified from the client —
//     admins approve/pay via the Firebase Console or a Cloud Function.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Admin check ──────────────────────────────────────────────
    // Admin UIDs are hard-coded here for simplicity. Must match the
    // ADMIN_UIDS array in index.html. To add an admin:
    //   1. Find their UID in Firebase Console → Authentication → Users
    //   2. Add to both this list AND the ADMIN_UIDS const in index.html
    //   3. Publish updated rules.
    function isAdmin() {
      return request.auth != null && request.auth.uid in [
        'uaiU5Afc1gMowVL37hTzJpSNqBT2'
      ];
    }

    // ─── Users ────────────────────────────────────────────────────
    // Any authenticated user can READ user docs (needed to look up a
    // referrer by referralCode). Write is restricted to the owner.
    match /users/{uid} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid
                       // Never let a user set their own referredBy to themselves
                       && (!('referredBy' in request.resource.data)
                           || request.resource.data.referredBy != request.auth.uid);
      allow delete: if false;
    }

    // ─── Referrals ────────────────────────────────────────────────
    // Read: only if you're the referrer or referee.
    // Create: only by the referee, only pending, can't self-refer.
    // Update: only by referee, only pending → active, and reward/referrer are locked.
    match /referrals/{id} {
      allow read: if request.auth != null
                    && (resource.data.referrerId == request.auth.uid
                        || resource.data.refereeId  == request.auth.uid);

      allow create: if request.auth != null
                    && request.resource.data.refereeId  == request.auth.uid
                    && request.resource.data.referrerId != request.auth.uid
                    && request.resource.data.status     == 'pending'
                    && request.resource.data.rewardAmount is number
                    && request.resource.data.rewardAmount > 0
                    && request.resource.data.rewardAmount <= 100;  // cap to prevent inflated codes

      allow update: if request.auth != null
                    && resource.data.refereeId == request.auth.uid
                    && resource.data.status    == 'pending'
                    && request.resource.data.status == 'active'
                    // Immutable fields
                    && request.resource.data.referrerId   == resource.data.referrerId
                    && request.resource.data.refereeId    == resource.data.refereeId
                    && request.resource.data.rewardAmount == resource.data.rewardAmount
                    && request.resource.data.rewardCurrency == resource.data.rewardCurrency;

      allow delete: if false;
    }

    // ─── Withdrawals ──────────────────────────────────────────────
    // Users submit requests; only admin (Firebase Console) processes them.
    match /withdrawals/{id} {
      allow read:   if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.amount is number
                    && request.resource.data.amount > 0;
      allow update: if false;
      allow delete: if false;
    }

    // ─── Wallet Transactions ──────────────────────────────────────
    // Three valid creation paths, each strictly shape-validated:
    //   1. Deposit   — self credits own wallet from external MoMo
    //   2. Withdraw  — self debits own wallet to external MoMo
    //   3. Send      — self debits own wallet, credits another SafeSpend user
    //
    // Balance is COMPUTED on the client (sum of incoming − outgoing completed
    // transactions), so no user can write a balance on anyone else's account.
    // External MoMo counterparties use the sentinel id format "momo:*".
    match /walletTransactions/{id} {
      allow read: if request.auth != null
                    && (resource.data.senderId    == request.auth.uid
                        || resource.data.recipientId == request.auth.uid);

      allow create: if request.auth != null
                    && request.resource.data.amount is number
                    && request.resource.data.amount > 0
                    && request.resource.data.amount <= 10000
                    && request.resource.data.status in ['pending', 'completed']
                    && (
                      // Deposit: recipient is self, sender is external MoMo
                      (request.resource.data.type == 'deposit'
                        && request.resource.data.recipientId == request.auth.uid
                        && request.resource.data.senderId.matches('momo:.*'))
                      ||
                      // Withdraw: sender is self, recipient is external MoMo
                      (request.resource.data.type == 'withdraw'
                        && request.resource.data.senderId == request.auth.uid
                        && request.resource.data.recipientId.matches('momo:.*'))
                      ||
                      // Send: sender is self, recipient is a different real user
                      (request.resource.data.type == 'send'
                        && request.resource.data.senderId == request.auth.uid
                        && request.resource.data.recipientId != request.auth.uid
                        && !request.resource.data.recipientId.matches('momo:.*'))
                    );

      // Transactions are an immutable audit trail — no client updates/deletes.
      allow update, delete: if false;
    }

    // ─── Revenue Events (APP EARNINGS) ────────────────────────────
    // This is the source of truth for SafeSpend's earnings. User funds live
    // in /walletTransactions — app earnings live HERE, strictly separated.
    //
    // Create: any authenticated user (fee events are logged from the
    //   client when they pay fees). Client-side validation prevents
    //   inflated events via amount bounds below.
    // Read:   admin only (privacy — revenue data is the owner's business).
    // Update/Delete: never — immutable audit trail.
    match /revenueEvents/{id} {
      allow read: if isAdmin();

      allow create: if request.auth != null
                    && request.resource.data.amount is number
                    && request.resource.data.amount > 0
                    && request.resource.data.amount <= 100
                    && request.resource.data.type in ['fee_deposit', 'fee_send', 'fee_withdraw', 'subscription'];

      allow update, delete: if false;
    }

    // ─── Owner Withdrawals ────────────────────────────────────────
    // Admin-only collection where the app owner requests payouts of their
    // earnings. Read/create restricted to admins; updates manual via
    // Firebase Console (change status → 'paid' after sending the money).
    match /ownerWithdrawals/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin()
                    && request.resource.data.amount is number
                    && request.resource.data.amount > 0
                    && request.resource.data.status == 'pending';
      allow update, delete: if false;
    }
  }
}
