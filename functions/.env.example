# SafeSpend Cloud Functions environment template
# Copy this file to `.env` and fill in your real values.
#
# IMPORTANT:
#   • Never commit .env to git (it's in .gitignore).
#   • Never expose these values in the frontend (index.html).
#   • Secrets should also be set via `firebase functions:config:set` for v1
#     deployments — see PAYMENT-GATEWAY-SETUP.md.

# ─── Flutterwave ─────────────────────────────────────────────────
# Test secret key (starts with FLWSECK_TEST-)
# Live secret key (starts with FLWSECK-)
# Find both at: https://dashboard.flutterwave.com/settings/apis
FLW_SECRET_KEY=FLWSECK_TEST-XXXXXXXXXXXXXXXXXXXXXXXXX-X

# Webhook secret hash — any random string >= 16 chars.
# Set the SAME value at: Flutterwave Dashboard → Settings → Webhooks → "Secret hash"
FLW_SECRET_HASH=replace-with-random-32-char-string
