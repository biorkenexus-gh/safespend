# SafeSpend Cloud Functions environment template
# Copy this file to `.env` and fill in real values for the gateway(s) you use.
#
# IMPORTANT:
#   • Never commit .env to git (it's in .gitignore).
#   • Never expose these values in the frontend (index.html).
#   • For prod: prefer `firebase functions:config:set` (see PAYMENT-GATEWAY-SETUP.md).
#   • You only need keys for the gateway(s) you actually enable. SafeSpend
#     supports running with just one provider, or both side-by-side.

# ─── Flutterwave ─────────────────────────────────────────────────
# Test  secret key starts with FLWSECK_TEST-
# Live  secret key starts with FLWSECK-
# Find both at: https://dashboard.flutterwave.com/settings/apis
FLW_SECRET_KEY=FLWSECK_TEST-XXXXXXXXXXXXXXXXXXXXXXXXX-X

# Webhook secret hash — any random string ≥ 16 chars (≥ 32 recommended).
# Set the SAME value at: Flutterwave Dashboard → Settings → Webhooks → "Secret hash"
FLW_SECRET_HASH=replace-with-random-32-char-string

# ─── Paystack ────────────────────────────────────────────────────
# Test  secret key starts with sk_test_
# Live  secret key starts with sk_live_
# Find both at: https://dashboard.paystack.com/#/settings/developer
#
# Paystack uses the SECRET key to sign webhooks (HMAC-SHA512). There is
# no separate webhook secret — same key signs incoming events.
PSTK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
